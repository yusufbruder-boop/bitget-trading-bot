# Bitget API (Pflicht) — von https://www.bitget.com/de/account/newapi
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# true = nur simulierte Orders (trotzdem echte API für Positions-Check)
PAPER_TRADING=true

# Trading
LEVERAGE=1
TP_PERCENT=1.2
SL_PERCENT=0.6
TIMEFRAME=5m
PORTFOLIO_VALUE_USD=253
MAX_TRADE_SIZE_USD=25
MAX_TRADES_PER_DAY=0

# Laufzeit
# Dauer-Loop: Intervall zwischen zwei kompletten Analysen (ms)
BOT_INTERVAL_MS=60000

# Optionale News-/Sentiment-Feeds
# NewsAPI: https://newsapi.org
NEWSAPI_KEY=

# X API Bearer Token für Posts von marktbewegenden Accounts
X_API_BEARER_TOKEN=
X_INFLUENCER_USERS=realDonaldTrump,POTUS,WhiteHouse,federalreserve,USTreasury,SecScottBessent,elonmusk

# HTTP /health — Railway braucht Listener auf $PORT; SKIP_HEALTH_SERVER dort ignorieren/löschen
# Lokal ohne Port:
# SKIP_HEALTH_SERVER=true
# HEALTH_PORT=8080
